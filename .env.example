# ── Supabase (backend compartilhado RH + SAC) ───────────────────────────────
# Mesmo project ref usado em ../SAC/.env.local e ../RH/.env.local (fonte única).
NEXT_PUBLIC_SUPABASE_URL=https://lkiihnxznphxqekrgsgi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — só no servidor (webhooks/crons). NUNCA no browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── UAZAPI (WhatsApp) ────────────────────────────────────────────────────────
# Auth por header `token` (a instância é identificada pelo próprio token).
# 1 instância/número por unidade. Webhook aponta para:
#   https://<dominio>/api/webhooks/uazapi?secret=<UAZAPI_WEBHOOK_SECRET>
UAZAPI_BASE_URL=
UAZAPI_TOKEN=
UAZAPI_WEBHOOK_SECRET=

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
UAZAPI_ADMIN_TOKEN=

# ── Site institucional (lasercompany.com — Supabase SEPARADO, projeto riut) ──
# Necessário para a ponte ler/sincronizar lasercompany_leads (a anon key nao le por RLS).
SITE_SUPABASE_URL=https://riutcbwillvqjrpaefkb.supabase.co
SITE_SUPABASE_SERVICE_KEY=
